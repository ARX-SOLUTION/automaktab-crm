{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount}}
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="page-eyebrow">Talabalar boshqaruvi</span>
        <h1 class="page-title">{{pageTitle}}</h1>
        <p class="page-description">{{pageDescription}}</p>
      </div>
      <div class="page-actions">
        <button class="btn-primary" type="button" data-modal-open="student-create-modal">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Talaba qo'shish
        </button>
      </div>
    </section>

    <div class="tab-nav">
      <a class="tab-btn {{#unless filters.courseType}}active{{/unless}}{{#ifEquals filters.courseType '' }}active{{/ifEquals}}" href="/app/students?{{#if filters.branchId}}branchId={{filters.branchId}}&{{/if}}{{#if filters.search}}search={{filters.search}}&{{/if}}{{#if filters.status}}status={{filters.status}}{{/if}}">
        Barchasi
        <span class="tab-count">{{meta.total}}</span>
      </a>
      <a class="tab-btn {{ifEquals filters.courseType 'express' 'active'}}" href="/app/students?courseType=express{{#if filters.branchId}}&branchId={{filters.branchId}}{{/if}}{{#if filters.search}}&search={{filters.search}}{{/if}}{{#if filters.status}}&status={{filters.status}}{{/if}}">
        Tezkor kurs
      </a>
      <a class="tab-btn {{ifEquals filters.courseType 'standard' 'active'}}" href="/app/students?courseType=standard{{#if filters.branchId}}&branchId={{filters.branchId}}{{/if}}{{#if filters.search}}&search={{filters.search}}{{/if}}{{#if filters.status}}&status={{filters.status}}{{/if}}">
        Avto maktab kursi
      </a>
    </div>

    <form class="filters-bar filter-card" method="GET" action="/app/students">
      {{#if filters.courseType}}<input type="hidden" name="courseType" value="{{filters.courseType}}">{{/if}}
      <div class="filter-group">
        <label>Qidiruv</label>
        <input type="search" name="search" value="{{filters.search}}" placeholder="Ism, familya yoki telefon">
      </div>
      <div class="filter-group">
        <label>Filial</label>
        <select name="branchId" {{#unless user.isOwner}}disabled{{/unless}}>
          {{{branchOptions branches user filters.branchId}}}
        </select>
      </div>
      <div class="filter-group">
        <label>To'lov holati</label>
        <select name="status">
          <option value="">Barchasi</option>
          <option value="paid" {{ifEquals filters.status 'paid' 'selected'}}>To'langan</option>
          <option value="unpaid" {{ifEquals filters.status 'unpaid' 'selected'}}>Qarzdor</option>
        </select>
      </div>
      <div class="filter-actions">
        <button class="btn-secondary" type="submit">Qo'llash</button>
        <a class="btn-ghost" href="/app/students{{#if filters.courseType}}?courseType={{filters.courseType}}{{/if}}">Tozalash</a>
      </div>
    </form>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon-wrap bg-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Jami natija</span>
          <h3>{{meta.total}}</h3>
          <small>Joriy filter bo'yicha</small>
        </div>
      </div>
      <div class="stat-card success">
        <div class="stat-icon-wrap bg-success">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Jami tushum</span>
          <h3>{{formatUZS summary.totalPaid}}</h3>
          <small>{{stats.paidCount}} ta to'langan</small>
        </div>
      </div>
      <div class="stat-card warning">
        <div class="stat-icon-wrap bg-danger">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Qarzdorlik</span>
          <h3>{{formatUZS summary.totalDebt}}</h3>
          <small>{{stats.debtCount}} ta qarzdor</small>
        </div>
      </div>
      <div class="stat-card info">
        <div class="stat-icon-wrap bg-info">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Jami kontrakt</span>
          <h3>{{formatUZS summary.totalPrices}}</h3>
          <small>Umumiy kurs narxlari</small>
        </div>
      </div>
    </div>

    <section class="data-card">
      {{> student-table students=students summary=summary isOwner=user.isOwner}}

      {{#if meta.totalPages}}
        <div class="table-section-footer">
          {{> pagination meta=meta filters=filters}}
        </div>
      {{/if}}
    </section>

    {{> student-form-modal user=user branches=branches groups=groups}}
  </div>

  <section class="management-section">
    <div class="section-heading" style="padding:1.2rem 1.25rem">
      <div>
        <h3>Tahrirlash va to'lov amallari</h3>
        <p>Har bir talaba bo'yicha ma'lumot, to'lov va o'chirish amallarini modal orqali boshqaring.</p>
      </div>
    </div>
    {{#each students}}
      <div class="modal embedded-modal" id="student-edit-{{id}}">
        <div class="modal-content modal-xl">
          <button class="modal-close" type="button" data-modal-close="student-edit-{{id}}">&times;</button>
          <div class="modal-header">
            <h4>{{lastName}} {{firstName}}</h4>
            <p>{{courseTypeLabel courseType}} &bull; {{branch.name}}</p>
          </div>
          <div class="embedded-grid">
            <form action="/app/students/{{id}}/update" method="POST" class="form-grid">
              <label>Familiya<input type="text" name="lastName" value="{{lastName}}" required></label>
              <label>Ismi<input type="text" name="firstName" value="{{firstName}}" required></label>
              <label>Telefon<input type="text" name="phone" value="{{phone}}" required></label>
              <label>Kurs narxi<input type="number" name="totalPrice" value="{{totalPrice}}" min="0"></label>
              {{#ifEquals courseType 'standard'}}
                <label>
                  Guruh
                  <select name="groupId">
                    <option value="">Guruhni tanlang</option>
                    {{#each ../groups}}
                      <option value="{{id}}" {{ifEquals ../group.id id 'selected'}}>{{branchName}} — {{name}}</option>
                    {{/each}}
                  </select>
                </label>
                <label>Shartnoma<input type="text" name="contractNumber" value="{{contractNumber}}"></label>
              {{/ifEquals}}
              <label class="span-2">Izoh<textarea name="notes" rows="3">{{notes}}</textarea></label>
              <button class="btn-primary span-2" type="submit">Ma'lumotlarni saqlash</button>
            </form>
            <form action="/app/students/{{id}}/payment" method="POST" class="form-grid">
              {{#ifEquals courseType 'express'}}
                <label>To'lov<input type="number" name="amountPaid" value="{{initialPayment}}" min="0"></label>
              {{else}}
                <label>1-to'lov<input type="number" name="initialPayment" value="{{initialPayment}}" min="0"></label>
                <label>2-to'lov<input type="number" name="secondPayment" value="{{secondPayment}}" min="0"></label>
                <label>3-to'lov<input type="number" name="thirdPayment" value="{{thirdPayment}}" min="0"></label>
              {{/ifEquals}}
              <button class="btn-secondary span-2" type="submit">To'lovni yangilash</button>
            </form>
            <form action="/app/students/{{id}}/delete" method="POST" class="danger-form">
              <button class="btn-danger" type="submit">Talabani o'chirish</button>
            </form>
          </div>
        </div>
      </div>
    {{/each}}
  </section>
{{/main}}
