{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount pageDescription=pageDescription}}
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="page-eyebrow">Talabalar boshqaruvi</span>
        <h1 class="page-title">{{pageTitle}}</h1>
        <p class="page-description">{{pageDescription}}</p>
      </div>
      <div class="page-actions">
        <button class="btn-primary" type="button" data-modal-open="student-create-modal">Talaba qo'shish</button>
      </div>
    </section>

    <nav class="course-tabs" aria-label="Kurs turi filtrlari">
      <a class="course-tab {{#unless filters.courseType}}is-active{{/unless}}" href="/app/students{{queryString filters courseType='' page=1 limit=meta.limit}}">
        <strong>Barcha kurslar</strong>
        <span>Express va to'liq kurslar birga</span>
      </a>
      <a class="course-tab {{#ifEquals filters.courseType 'express'}}is-active{{/ifEquals}}" href="/app/students{{queryString filters courseType='express' page=1 limit=meta.limit}}">
        <strong>Tezkor kurs</strong>
        <span>Bir martalik yoki ixcham to'lov oqimi</span>
      </a>
      <a class="course-tab {{#ifEquals filters.courseType 'standard'}}is-active{{/ifEquals}}" href="/app/students{{queryString filters courseType='standard' page=1 limit=meta.limit}}">
        <strong>To'liq kurs</strong>
        <span>Guruh va bo'lib-bo'lib to'lov bilan</span>
      </a>
    </nav>

    <form class="filters-bar filter-card" method="GET" action="/app/students">
      <div class="filter-group">
        <label>Qidiruv</label>
        <input type="search" name="search" value="{{filters.search}}" placeholder="Ism, familya yoki telefon">
      </div>
      <div class="filter-group">
        <label>Filial</label>
        <select name="branchId" {{#unless user.isOwner}}disabled{{/unless}}>
          {{{branchOptions branches user filters.branchId}}}
        </select>
      </div>
      <div class="filter-group">
        <label>To'lov holati</label>
        <select name="status">
          <option value="">Barchasi</option>
          <option value="paid" {{ifEquals filters.status 'paid' 'selected'}}>To'langan</option>
          <option value="unpaid" {{ifEquals filters.status 'unpaid' 'selected'}}>Qarzdor</option>
        </select>
      </div>
      <div class="filter-actions">
        <button class="btn-secondary" type="submit">Filtrni qo'llash</button>
        <a class="btn-ghost" href="/app/students{{#if filters.courseType}}{{queryString filters search='' branchId='' status='' page=1 limit=meta.limit}}{{else}}{{/if}}">Tozalash</a>
      </div>
    </form>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-body">
          <span class="stat-label">Sahifadagi talabalar</span>
          <h3>{{meta.total}}</h3>
          <small>Joriy filter bo'yicha natija</small>
        </div>
      </div>
      <div class="stat-card success">
        <div class="stat-body">
          <span class="stat-label">Jami tushum</span>
          <h3>{{formatUZS summary.totalPaid}}</h3>
          <small>{{stats.paidCount}} ta to'langan talaba</small>
        </div>
      </div>
      <div class="stat-card warning">
        <div class="stat-body">
          <span class="stat-label">Qarzdorlik</span>
          <h3>{{formatUZS summary.totalDebt}}</h3>
          <small>{{stats.debtCount}} ta qarzdor talaba</small>
        </div>
      </div>
      <div class="stat-card info">
        <div class="stat-body">
          <span class="stat-label">Jami kontrakt</span>
          <h3>{{formatUZS summary.totalPrices}}</h3>
          <small>Umumiy kurs narxlari</small>
        </div>
      </div>
    </div>

    <section class="data-card">
      <div class="table-card-header">
        <div>
          <h3>Talabalar jadvali</h3>
          <p>{{meta.total}} ta natija topildi. Kurs turi tablari keng ko'rinishni, filterlar esa tezkor saralashni boshqaradi.</p>
        </div>
        <span class="badge">{{#if filters.courseType}}{{courseTypeLabel filters.courseType}}{{else}}Barcha kurslar{{/if}}</span>
      </div>
      {{> student-table students=students summary=summary filters=filters isOwner=user.isOwner}}

      {{#if meta.totalPages}}
        <div class="table-section-footer">
          {{> pagination meta=meta filters=filters}}
        </div>
      {{/if}}
    </section>

    {{> student-form-modal user=user branches=branches groups=groups}}
  </div>

  <section class="management-section">
    <div class="section-heading">
      <div>
        <h3>Tahrirlash va to'lov amallari</h3>
        <p>Har bir talaba bo'yicha ma'lumot, to'lov va o'chirish amallarini modal orqali boshqaring.</p>
      </div>
    </div>
    {{#each students}}
      <div class="modal embedded-modal" id="student-edit-{{id}}">
        <div class="modal-content modal-xl">
          <button class="modal-close" type="button" data-modal-close="student-edit-{{id}}">×</button>
          <div class="modal-header">
            <h4>{{lastName}} {{firstName}}</h4>
            <p>{{courseTypeLabel courseType}} • {{branch.name}}</p>
          </div>
          <div class="embedded-grid">
            <form action="/app/students/{{id}}/update" method="POST" class="form-grid">
              <label>Familiya<input type="text" name="lastName" value="{{lastName}}" required></label>
              <label>Ismi<input type="text" name="firstName" value="{{firstName}}" required></label>
              <label>Telefon<input type="text" name="phone" value="{{phone}}" required></label>
              <label>Kurs narxi<input type="number" name="totalPrice" value="{{totalPrice}}" min="0"></label>
              <label>
                To'lov turi
                <select name="paymentMethod">
                  <option value="" {{#unless paymentMethod}}selected{{/unless}}>Tanlanmagan</option>
                  <option value="cash" {{ifEquals paymentMethod 'cash' 'selected'}}>Naqd</option>
                  <option value="card" {{ifEquals paymentMethod 'card' 'selected'}}>Karta</option>
                  <option value="transfer" {{ifEquals paymentMethod 'transfer' 'selected'}}>O'tkazma</option>
                </select>
              </label>
              <label>
                Talaba holati
                <select name="status">
                  <option value="" {{#unless status}}selected{{/unless}}>O'zgartirilmasin</option>
                  <option value="active" {{ifEquals status 'active' 'selected'}}>Faol</option>
                  <option value="completed" {{ifEquals status 'completed' 'selected'}}>Yakunlangan</option>
                  <option value="dropped" {{ifEquals status 'dropped' 'selected'}}>Tashlab ketgan</option>
                  <option value="suspended" {{ifEquals status 'suspended' 'selected'}}>To'xtatilgan</option>
                </select>
              </label>
              <label>
                Imtihon natijasi
                <select name="result">
                  <option value="" {{#unless result}}selected{{/unless}}>Kutilmoqda</option>
                  <option value="pending" {{ifEquals result 'pending' 'selected'}}>Kutilmoqda</option>
                  <option value="passed" {{ifEquals result 'passed' 'selected'}}>O'tgan</option>
                  <option value="failed" {{ifEquals result 'failed' 'selected'}}>Yiqilgan</option>
                </select>
              </label>
              <label>
                Hujjat
                <select name="hasDocument">
                  <option value="true" {{ifEquals hasDocument true 'selected'}}>Bor</option>
                  <option value="false" {{ifEquals hasDocument false 'selected'}}>Yo'q</option>
                </select>
              </label>
              {{#ifEquals courseType 'standard'}}
                <label>
                  Guruh
                  <select name="groupId">
                    <option value="">Guruhni tanlang</option>
                    {{#each ../groups}}
                      <option value="{{id}}" {{ifEquals ../group.id id 'selected'}}>{{branchName}} — {{name}}</option>
                    {{/each}}
                  </select>
                </label>
                <label>Shartnoma<input type="text" name="contractNumber" value="{{contractNumber}}"></label>
                <label>Yakun sanasi<input type="date" name="completionDate" value="{{dateInputValue completionDate}}"></label>
                <label>
                  O83
                  <select name="o83">
                    <option value="true" {{ifEquals o83 true 'selected'}}>Ha</option>
                    <option value="false" {{ifEquals o83 false 'selected'}}>Yo'q</option>
                  </select>
                </label>
              {{/ifEquals}}
              <label class="span-2">Izoh<textarea name="notes" rows="3">{{notes}}</textarea></label>
              <button class="btn-primary span-2" type="submit" data-loading-text="Saqlanmoqda...">Ma'lumotlarni saqlash</button>
            </form>
            <form action="/app/students/{{id}}/payment" method="POST" class="form-grid">
              {{#ifEquals courseType 'express'}}
                <label>To'lov<input type="number" name="amountPaid" value="{{initialPayment}}" min="0"></label>
              {{else}}
                <label>1-to'lov<input type="number" name="initialPayment" value="{{initialPayment}}" min="0"></label>
                <label>2-to'lov<input type="number" name="secondPayment" value="{{secondPayment}}" min="0"></label>
                <label>3-to'lov<input type="number" name="thirdPayment" value="{{thirdPayment}}" min="0"></label>
              {{/ifEquals}}
              <button class="btn-secondary span-2" type="submit" data-loading-text="Yangilanmoqda...">To'lovni yangilash</button>
            </form>
            <section class="form-panel payment-overview-panel span-2">
              <div class="payment-overview-head">
                <div>
                  <strong>To'lov ko'rinishi</strong>
                  <span>Joriy balans va oxirgi o'zgarishlarni shu joyning o'zida kuzating.</span>
                </div>
                <span class="{{paymentStatusClass paymentStatus}}">{{paymentStatusLabel paymentStatus}}</span>
              </div>
              <div class="payment-summary-grid">
                <article class="payment-summary-card">
                  <span>Jami to'langan</span>
                  <strong>{{formatUZS paidTotal}}</strong>
                </article>
                <article class="payment-summary-card">
                  <span>Qoldiq</span>
                  <strong>{{formatUZS debt}}</strong>
                </article>
                <article class="payment-summary-card">
                  <span>Kurs narxi</span>
                  <strong>{{formatUZS totalPrice}}</strong>
                </article>
                <article class="payment-summary-card">
                  <span>To'lov usuli</span>
                  <strong>{{paymentMethodLabel paymentMethod}}</strong>
                </article>
              </div>
              <div class="progress-meta">
                <span>{{paymentProgress}}% yopilgan</span>
                <span>Oxirgi yangilanish: {{formatDateUZ updatedAt}}</span>
              </div>
              <div class="progress-bar-wrap" aria-hidden="true">
                <div class="progress-bar-fill" style="width: {{paymentProgress}}%;"></div>
              </div>
              <div
                class="payment-history-card"
                data-payment-history
                data-student-id="{{id}}"
                data-payment-history-url="/students/{{id}}/payment-history"
              >
                <div class="payment-history-header">
                  <div>
                    <strong>To'lov tarixi</strong>
                    <span>Modal ochilganda oxirgi to'lov o'zgarishlari avtomatik yuklanadi.</span>
                  </div>
                  <button class="btn-ghost btn-history-refresh" type="button" data-payment-history-refresh>Yangilash</button>
                </div>
                <div class="payment-history-list" data-payment-history-content>
                  <div class="payment-history-placeholder">
                    <strong>Tarix tayyor</strong>
                    <span>Bu modalni ochganingizda to'lov loglari shu yerda ko'rinadi.</span>
                  </div>
                </div>
              </div>
            </section>
            <div class="danger-form span-2">
              <button
                class="btn-danger"
                type="button"
                data-modal-open="delete-modal"
                data-confirm-action="/app/students/{{id}}/delete"
                data-confirm-title="Talabani o'chirish"
                data-confirm-description="{{lastName}} {{firstName}} yozuvini butunlay o'chirmoqchimisiz?"
                data-confirm-button="Ha, o'chirish"
              >
                Talabani o'chirish
              </button>
            </div>
          </div>
        </div>
      </div>
    {{/each}}
  </section>
{{/main}}
