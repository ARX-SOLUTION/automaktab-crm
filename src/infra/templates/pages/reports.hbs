{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount pageDescription=pageDescription}}
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="page-eyebrow">Moliyaviy nazorat</span>
        <h1 class="page-title">{{pageTitle}}</h1>
        <p class="page-description">{{pageDescription}}</p>
      </div>
      <div class="page-actions">
        <a class="btn-secondary" href="/app/reports">Tozalash</a>
      </div>
    </section>

    <form class="filters-bar filter-card" method="GET" action="/app/reports">
      <div class="filter-group">
        <label>Filial</label>
        <select name="branchId">
          <option value="">Barcha filiallar</option>
          {{#each branches}}
            <option value="{{id}}" {{ifEquals ../filters.branchId id 'selected'}}>{{name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="filter-group">
        <label>Kurs turi</label>
        <select name="courseType">
          <option value="">Barchasi</option>
          <option value="express" {{ifEquals filters.courseType 'express' 'selected'}}>Tezkor kurs</option>
          <option value="standard" {{ifEquals filters.courseType 'standard' 'selected'}}>To'liq kurs</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Boshlanish sanasi</label>
        <input type="date" name="startDate" value="{{filters.startDate}}">
      </div>
      <div class="filter-group">
        <label>Tugash sanasi</label>
        <input type="date" name="endDate" value="{{filters.endDate}}">
      </div>
      <div class="filter-actions">
        <button class="btn-secondary" type="submit">Hisobotni yangilash</button>
        <a class="btn-ghost" href="/app/reports">Filtrni tozalash</a>
      </div>
    </form>

    <div class="stats-grid">
      <div class="stat-card success">
        <div class="stat-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M4 12h16M12 4v16M6 6h12v12H6z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Jami tushum</span>
          <h3>{{formatUZS revenue.totalRevenue}}</h3>
          <small>Tanlangan oraliq bo'yicha real tushum</small>
        </div>
      </div>
      <div class="stat-card warning">
        <div class="stat-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M12 3l8 14H4l8-14zm0 5v4m0 3h.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Qarzdorlik</span>
          <h3>{{formatUZS revenue.totalDebt}}</h3>
          <small>Faol talabalar kesimidagi ochiq qarz</small>
        </div>
      </div>
      <div class="stat-card info">
        <div class="stat-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M5 19V5h14v14H5zm4-8h6m-6 4h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Talabalar soni</span>
          <h3>{{revenue.totalStudents}}</h3>
          <small>Hisobotga tushgan talabalar</small>
        </div>
      </div>
    </div>

    <div class="dashboard-panels dashboard-panels-two">
      <section class="data-card">
        <div class="table-card-header">
          <div>
            <h3>Filiallar kesimida tushum</h3>
            <p>Har bir filial bo'yicha tushum, qarzdorlik va talabalar soni.</p>
          </div>
        </div>
        <div class="table-wrapper">
          <table class="data-table compact-table">
            <thead>
              <tr>
                <th>Filial</th>
                <th class="text-right">Tushum</th>
                <th class="text-right">Qarzdorlik</th>
                <th class="text-right">Talabalar</th>
              </tr>
            </thead>
            <tbody>
              {{#if revenue.byBranch.length}}
                {{#each revenue.byBranch}}
                  <tr>
                    <td>{{branchName}}</td>
                    <td class="text-right tabular-nums">{{formatUZS revenue}}</td>
                    <td class="text-right tabular-nums {{debtClass debt}}">{{formatUZS debt}}</td>
                    <td class="text-right tabular-nums">{{studentCount}}</td>
                  </tr>
                {{/each}}
              {{else}}
                <tr class="table-empty-row">
                  <td colspan="4">{{> empty-state message="Filiallar bo'yicha hisobot topilmadi" icon="UZS" }}</td>
                </tr>
              {{/if}}
            </tbody>
          </table>
        </div>
      </section>

      <section class="data-card">
        <div class="table-card-header">
          <div>
            <h3>Kurs turi kesimida ko'rinish</h3>
            <p>Express va to'liq kurslar bo'yicha moliyaviy taqsimot.</p>
          </div>
        </div>
        <div class="table-wrapper">
          <table class="data-table compact-table">
            <thead>
              <tr>
                <th>Kurs turi</th>
                <th class="text-right">Tushum</th>
                <th class="text-right">Qarzdorlik</th>
                <th class="text-right">Talabalar</th>
              </tr>
            </thead>
            <tbody>
              {{#if revenue.byCourseType.length}}
                {{#each revenue.byCourseType}}
                  <tr>
                    <td>{{courseTypeLabel courseType}}</td>
                    <td class="text-right tabular-nums">{{formatUZS revenue}}</td>
                    <td class="text-right tabular-nums {{debtClass debt}}">{{formatUZS debt}}</td>
                    <td class="text-right tabular-nums">{{studentCount}}</td>
                  </tr>
                {{/each}}
              {{else}}
                <tr class="table-empty-row">
                  <td colspan="4">{{> empty-state message="Kurs turi bo'yicha hisobot topilmadi" icon="CR" }}</td>
                </tr>
              {{/if}}
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </div>
{{/main}}
