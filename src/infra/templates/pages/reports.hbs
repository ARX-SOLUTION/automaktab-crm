{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount}}
  <form class="filters-bar" method="GET" action="/app/reports">
    <div class="filter-group">
      <label>Filial</label>
      <select name="branchId">
        <option value="">Barchasi</option>
        {{#each branches}}
          <option value="{{id}}" {{ifEquals ../filters.branchId id 'selected'}}>{{name}}</option>
        {{/each}}
      </select>
    </div>
    <div class="filter-group">
      <label>Kurs turi</label>
      <select name="courseType">
        <option value="">Barchasi</option>
        <option value="express" {{ifEquals filters.courseType 'express' 'selected'}}>Tezkor kurs</option>
        <option value="standard" {{ifEquals filters.courseType 'standard' 'selected'}}>To'liq kurs</option>
      </select>
    </div>
    <div class="filter-group">
      <label>Boshlanish</label>
      <input type="date" name="startDate" value="{{filters.startDate}}">
    </div>
    <div class="filter-group">
      <label>Tugash</label>
      <input type="date" name="endDate" value="{{filters.endDate}}">
    </div>
    <button class="btn-secondary" type="submit">Qo'llash</button>
  </form>

  <div class="stats-grid">
    <div class="stat-card success"><div class="stat-body"><h3>{{formatUZS revenue.totalRevenue}}</h3><p>Jami tushum</p></div></div>
    <div class="stat-card warning"><div class="stat-body"><h3>{{formatUZS revenue.totalDebt}}</h3><p>Qarzdorlik</p></div></div>
    <div class="stat-card"><div class="stat-body"><h3>{{revenue.totalStudents}}</h3><p>Talabalar</p></div></div>
  </div>

  <div class="resource-list">
    {{#each revenue.byBranch}}
      <article class="resource-card">
        <h4>{{branchName}}</h4>
        <p>Tushum: {{formatUZS revenue}}</p>
        <p>Qarzdorlik: {{formatUZS debt}}</p>
        <p>Talabalar: {{studentCount}}</p>
      </article>
    {{/each}}
  </div>
{{/main}}
