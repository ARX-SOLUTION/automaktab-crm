{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount pageDescription=pageDescription}}
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="page-eyebrow">Guruhlar</span>
        <h1 class="page-title">{{pageTitle}}</h1>
        <p class="page-description">{{pageDescription}}</p>
      </div>
      <div class="page-actions">
        <button class="btn-primary" type="button" data-modal-open="group-create-modal">Yangi guruh</button>
      </div>
    </section>

    <form class="filters-bar filter-card" method="GET" action="/app/groups/overview">
      <div class="filter-group">
        <label>Qidiruv</label>
        <input type="search" name="search" value="{{filters.search}}" placeholder="Guruh nomi bo'yicha qidiring">
      </div>
      <div class="filter-group">
        <label>Filial</label>
        <select name="branchId">
          <option value="">Barcha filiallar</option>
          {{#each branches}}
            <option value="{{id}}" {{ifEquals ../filters.branchId id 'selected'}}>{{name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="filter-actions">
        <button class="btn-secondary" type="submit">Filtrni qo'llash</button>
        <a class="btn-ghost" href="/app/groups/overview">Tozalash</a>
      </div>
    </form>

    <section class="panel">
      <div class="section-heading">
        <div>
          <h3>Filiallar kesimidagi ko'rinish</h3>
          <p>Har bir filialdagi guruhlar va faol talabalar soni bo'yicha qisqa signal.</p>
        </div>
      </div>
      <div class="overview-grid">
        {{#if overview.length}}
          {{#each overview}}
            <article class="overview-card">
              <div class="overview-card-header">
                <div>
                  <h4>{{branch.name}}</h4>
                  <p>{{groups.length}} ta guruh</p>
                </div>
                <span class="badge">{{branch.name}}</span>
              </div>
              <ul class="plain-list overview-list">
                {{#if groups.length}}
                  {{#each groups}}
                    <li>
                      <div class="cell-stack">
                        <strong>{{name}}</strong>
                        <span class="cell-muted">Jami {{totalStudents}}, faol {{activeStudents}}</span>
                      </div>
                    </li>
                  {{/each}}
                {{else}}
                  <li>Bu filial bo'yicha guruh topilmadi.</li>
                {{/if}}
              </ul>
            </article>
          {{/each}}
        {{else}}
          {{> empty-state message="Overview uchun mos guruh topilmadi" icon="GR" }}
        {{/if}}
      </div>
    </section>

    <section class="data-card">
      <div class="table-card-header">
        <div>
          <h3>Guruhlar jadvali</h3>
          <p>Guruh nomi, filial birikmasi va talabalar soni bo'yicha asosiy boshqaruv jadvali.</p>
        </div>
        <span class="badge">{{groups.length}} ta guruh</span>
      </div>

      <div class="table-wrapper">
        <table class="data-table compact-table">
          <colgroup>
            <col class="col-index">
            <col class="col-name">
            <col class="col-branch">
            <col class="col-progress">
            <col class="col-status">
            <col class="col-date">
            <col class="col-actions">
          </colgroup>
          <thead>
            <tr>
              <th>#</th>
              <th>Guruh</th>
              <th>Filial</th>
              <th>Talabalar</th>
              <th>Holat</th>
              <th>Yangilangan sana</th>
              <th>Amallar</th>
            </tr>
          </thead>
          <tbody>
            {{#if groups.length}}
              {{#each groups}}
                <tr>
                  <td>{{add @index 1}}</td>
                  <td>
                    <div class="cell-stack">
                      <strong>{{name}}</strong>
                      <span class="cell-muted">{{id}}</span>
                    </div>
                  </td>
                  <td><span class="branch-badge">{{branchName}}</span></td>
                  <td>
                    <div class="group-progress">
                      <div class="group-progress-meta">
                        <span class="tabular-nums"><strong>{{activeStudents}}</strong>/{{totalStudents}}</span>
                        <span class="cell-muted">faol / jami</span>
                      </div>
                      <div class="group-progress-track">
                        <div class="group-progress-fill" style="width: {{progressPercent activeStudents totalStudents}}%;"></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="{{#if isActive}}status-pill success{{else}}status-pill neutral{{/if}}">
                      {{#if isActive}}Faol{{else}}Nofaol{{/if}}
                    </span>
                  </td>
                  <td>{{formatDateUZ updatedAt}}</td>
                  <td class="actions-cell">
                    <button class="btn-icon btn-edit" type="button" data-modal-open="group-edit-{{id}}">Tahrir</button>
                    {{#if totalStudents}}
                      <button class="btn-icon btn-delete" type="button" disabled title="Talabalar biriktirilgan guruhni o'chirib bo'lmaydi">
                        Band
                      </button>
                    {{else}}
                      <button
                        class="btn-icon btn-delete"
                        type="button"
                        data-modal-open="delete-modal"
                        data-confirm-action="/app/groups/{{id}}/delete"
                        data-confirm-title="Guruhni o'chirish"
                        data-confirm-description="{{name}} guruhini o'chirmoqchimisiz? Guruhda talabalar bo'lsa, tizim bu amalni rad etadi."
                        data-confirm-button="Ha, o'chirish"
                      >
                        O'chir
                      </button>
                    {{/if}}
                  </td>
                </tr>
              {{/each}}
            {{else}}
              <tr class="table-empty-row">
                <td colspan="7">{{> empty-state message="Tanlangan filter bo'yicha guruh topilmadi" icon="GR" }}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <div class="modal" id="group-create-modal">
    <div class="modal-content">
      <button class="modal-close" type="button" data-modal-close="group-create-modal">×</button>
      <div class="modal-header">
        <h3>Yangi guruh qo'shish</h3>
        <p>To'liq kurs uchun guruh nomi va filialini belgilang.</p>
      </div>
      <form action="/app/groups" method="POST" class="form-grid">
        <label>Nomi<input type="text" name="name" placeholder="Masalan, B-12" required></label>
        <label>
          Filial
          <select name="branchId" required>
            {{#each branches}}
              <option value="{{id}}">{{name}}</option>
            {{/each}}
          </select>
        </label>
        <div class="modal-actions span-2">
          <button class="btn-secondary" type="button" data-modal-close="group-create-modal">Bekor qilish</button>
          <button class="btn-primary" type="submit" data-loading-text="Saqlanmoqda...">Guruhni saqlash</button>
        </div>
      </form>
    </div>
  </div>

  {{#each groups}}
    <div class="modal" id="group-edit-{{id}}">
      <div class="modal-content">
        <button class="modal-close" type="button" data-modal-close="group-edit-{{id}}">×</button>
        <div class="modal-header">
          <h3>{{name}} guruhini tahrirlash</h3>
          <p>Guruh nomi va filial birikmasini yangilang.</p>
        </div>
        <form action="/app/groups/{{id}}/update" method="POST" class="form-grid">
          <label>Nomi<input type="text" name="name" value="{{name}}" required></label>
          <label>
            Filial
            <select name="branchId" required>
              {{#each ../branches}}
                <option value="{{id}}" {{ifEquals ../branchId id 'selected'}}>{{name}}</option>
              {{/each}}
            </select>
          </label>
          <div class="modal-actions span-2">
            <button class="btn-secondary" type="button" data-modal-close="group-edit-{{id}}">Yopish</button>
            <button class="btn-primary" type="submit" data-loading-text="Yangilanmoqda...">Saqlash</button>
          </div>
        </form>
      </div>
    </div>
  {{/each}}
{{/main}}
