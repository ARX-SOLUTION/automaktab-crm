{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount}}
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="page-eyebrow">Operatorlar</span>
        <h1 class="page-title">{{pageTitle}}</h1>
        <p class="page-description">{{pageDescription}}</p>
      </div>
    </section>

    <form class="filters-bar filter-card" method="GET" action="/app/managers">
      <div class="filter-group">
        <label>Qidiruv</label>
        <input type="search" name="search" value="{{filters.search}}" placeholder="Ism yoki telefon">
      </div>
      <div class="filter-group">
        <label>Filial</label>
        <select name="branchId">
          <option value="">Barcha filiallar</option>
          {{#each branches}}
            <option value="{{id}}" {{ifEquals ../filters.branchId id 'selected'}}>{{name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="filter-actions">
        <button class="btn-secondary" type="submit">Filtrni qo'llash</button>
        <a class="btn-ghost" href="/app/managers">Tozalash</a>
      </div>
    </form>

    <section class="resource-section">
      <div class="section-heading">
        <div>
          <h3>Yangi operator</h3>
          <p>Yangi filial operatorini qo'shing va boshlang'ich kirish ma'lumotlarini belgilang.</p>
        </div>
      </div>
      <form action="/app/managers" method="POST" class="form-grid inline-form">
        <label>F.I.SH<input type="text" name="fullName" required></label>
        <label>Telefon<input type="text" name="phone" required></label>
        <label>Parol<input type="password" name="password" required></label>
        <label>
          Filial
          <select name="branchId" required>
            {{#each branches}}
              <option value="{{id}}">{{name}}</option>
            {{/each}}
          </select>
        </label>
        <button class="btn-primary" type="submit">Operator qo'shish</button>
      </form>
    </section>

    <div class="resource-list resource-list-wide">
      {{#each managers}}
        <article class="resource-card">
          <div class="resource-card-header">
            <div>
              <h4>{{fullName}}</h4>
              <p>{{phone}}</p>
            </div>
            <span class="{{#if isActive}}status-pill success{{else}}status-pill danger{{/if}}">
              {{#if isActive}}Faol{{else}}Deaktiv{{/if}}
            </span>
          </div>
          <div class="resource-meta">
            <span>Filial: {{branchName}}</span>
          </div>
          <form action="/app/managers/{{id}}/update" method="POST" class="form-grid inline-form">
            <label>F.I.SH<input type="text" name="fullName" value="{{fullName}}"></label>
            <label>Telefon<input type="text" name="phone" value="{{phone}}"></label>
            <label>
              Filial
              <select name="branchId">
                {{#each ../branches}}
                  <option value="{{id}}" {{ifEquals ../branchId id 'selected'}}>{{name}}</option>
                {{/each}}
              </select>
            </label>
            <button class="btn-secondary" type="submit">Yangilash</button>
          </form>
          <form action="/app/managers/{{id}}/reset-password" method="POST" class="inline-form compact-form">
            <label>Yangi parol<input type="password" name="newPassword" required></label>
            <button class="btn-secondary" type="submit">Parolni almashtirish</button>
          </form>
          <form action="/app/managers/{{id}}/deactivate" method="POST">
            <button class="btn-danger" type="submit">Deaktivatsiya</button>
          </form>
        </article>
      {{/each}}
    </div>
  </div>
{{/main}}
