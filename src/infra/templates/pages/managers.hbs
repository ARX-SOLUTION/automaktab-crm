{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount pageDescription=pageDescription}}
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="page-eyebrow">Operatorlar</span>
        <h1 class="page-title">{{pageTitle}}</h1>
        <p class="page-description">{{pageDescription}}</p>
      </div>
      <div class="page-actions">
        <button class="btn-primary" type="button" data-modal-open="manager-create-modal">Yangi operator</button>
      </div>
    </section>

    <form class="filters-bar filter-card" method="GET" action="/app/managers">
      <div class="filter-group">
        <label>Qidiruv</label>
        <input type="search" name="search" value="{{filters.search}}" placeholder="Ism yoki telefon">
      </div>
      <div class="filter-group">
        <label>Filial</label>
        <select name="branchId">
          <option value="">Barcha filiallar</option>
          {{#each branches}}
            <option value="{{id}}" {{ifEquals ../filters.branchId id 'selected'}}>{{name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="filter-group">
        <label>Status</label>
        <select name="status">
          <option value="">Barchasi</option>
          <option value="active" {{ifEquals filters.status 'active' 'selected'}}>Faol</option>
          <option value="inactive" {{ifEquals filters.status 'inactive' 'selected'}}>Nofaol</option>
        </select>
      </div>
      <div class="filter-actions">
        <button class="btn-secondary" type="submit">Filtrni qo'llash</button>
        <a class="btn-ghost" href="/app/managers">Tozalash</a>
      </div>
    </form>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-body">
          <span class="stat-label">Jami operatorlar</span>
          <h3>{{summary.total}}</h3>
          <small>Joriy filter natijalari</small>
        </div>
      </div>
      <div class="stat-card success">
        <div class="stat-body">
          <span class="stat-label">Faol operatorlar</span>
          <h3>{{summary.active}}</h3>
          <small>Ishlayotgan hisoblar soni</small>
        </div>
      </div>
      <div class="stat-card warning">
        <div class="stat-body">
          <span class="stat-label">Nofaol operatorlar</span>
          <h3>{{summary.inactive}}</h3>
          <small>Qayta faollashtirish talab qiladigan hisoblar</small>
        </div>
      </div>
    </div>

    <section class="data-card">
      <div class="table-card-header">
        <div>
          <h3>Operatorlar jadvali</h3>
          <p>Operator profili, filial birikmasi va holatini modal orqali boshqaring.</p>
        </div>
        <span class="badge">{{managers.length}} ta operator</span>
      </div>

      <div class="table-wrapper">
        <table class="data-table compact-table">
          <colgroup>
            <col class="col-index">
            <col class="col-name">
            <col class="col-phone">
            <col class="col-branch">
            <col class="col-status">
            <col class="col-date">
            <col class="col-actions">
          </colgroup>
          <thead>
            <tr>
              <th>#</th>
              <th>Operator</th>
              <th>Telefon</th>
              <th>Filial</th>
              <th>Status</th>
              <th>Qo'shilgan sana</th>
              <th>Amallar</th>
            </tr>
          </thead>
          <tbody>
            {{#if managers.length}}
              {{#each managers}}
                <tr class="{{#unless isActive}}muted-row{{/unless}}">
                  <td>{{add @index 1}}</td>
                  <td>
                    <div class="cell-stack">
                      <strong>{{fullName}}</strong>
                      <span class="cell-muted">{{id}}</span>
                    </div>
                  </td>
                  <td>{{phone}}</td>
                  <td>
                    <span class="branch-badge">{{branchName}}</span>
                  </td>
                  <td>
                    <span class="{{#if isActive}}status-pill success{{else}}status-pill neutral{{/if}}">
                      {{#if isActive}}Faol{{else}}Nofaol{{/if}}
                    </span>
                  </td>
                  <td>{{formatDateUZ createdAt}}</td>
                  <td class="actions-cell">
                    <button class="btn-icon btn-edit" type="button" data-modal-open="manager-edit-{{id}}">Tahrir</button>
                    <button class="btn-icon" type="button" data-modal-open="manager-password-{{id}}">Parol</button>
                    {{#if isActive}}
                      <button
                        class="btn-icon btn-delete"
                        type="button"
                        data-modal-open="delete-modal"
                        data-confirm-action="/app/managers/{{id}}/deactivate"
                        data-confirm-title="Operatorni deaktivatsiya qilish"
                        data-confirm-description="{{fullName}} operatorini nofaol holatga o'tkazmoqchimisiz?"
                        data-confirm-button="Ha, deaktivatsiya"
                      >
                        Deaktiv
                      </button>
                    {{else}}
                      <form action="/app/managers/{{id}}/activate" method="POST">
                        <button class="btn-icon btn-edit" type="submit" data-loading-text="Faollashmoqda...">Faollashtir</button>
                      </form>
                    {{/if}}
                  </td>
                </tr>
              {{/each}}
            {{else}}
              <tr class="table-empty-row">
                <td colspan="7">{{> empty-state message="Tanlangan filter bo'yicha operator topilmadi" icon="OP" }}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <div class="modal" id="manager-create-modal">
    <div class="modal-content">
      <button class="modal-close" type="button" data-modal-close="manager-create-modal">×</button>
      <div class="modal-header">
        <h3>Yangi operator qo'shish</h3>
        <p>Yangi filial operatorini yarating va boshlang'ich kirish ma'lumotlarini belgilang.</p>
      </div>
      <form action="/app/managers" method="POST" class="form-grid">
        <label>F.I.SH<input type="text" name="fullName" placeholder="Masalan, Ali Valiyev" required></label>
        <label>Telefon<input type="text" name="phone" placeholder="+998 90 123 45 67" required></label>
        <label>Parol<input type="password" name="password" placeholder="Kamida 6 ta belgi" required></label>
        <label>
          Filial
          <select name="branchId" required>
            {{#each branches}}
              <option value="{{id}}">{{name}}</option>
            {{/each}}
          </select>
        </label>
        <div class="modal-actions span-2">
          <button class="btn-secondary" type="button" data-modal-close="manager-create-modal">Bekor qilish</button>
          <button class="btn-primary" type="submit" data-loading-text="Saqlanmoqda...">Operatorni saqlash</button>
        </div>
      </form>
    </div>
  </div>

  {{#each managers}}
    <div class="modal" id="manager-edit-{{id}}">
      <div class="modal-content">
        <button class="modal-close" type="button" data-modal-close="manager-edit-{{id}}">×</button>
        <div class="modal-header">
          <h3>{{fullName}} operatorini tahrirlash</h3>
          <p>Kontakt va filial birikmasini yangilang.</p>
        </div>
        <form action="/app/managers/{{id}}/update" method="POST" class="form-grid">
          <label>F.I.SH<input type="text" name="fullName" value="{{fullName}}" required></label>
          <label>Telefon<input type="text" name="phone" value="{{phone}}" required></label>
          <label class="span-2">
            Filial
            <select name="branchId" required>
              {{#each ../branches}}
                <option value="{{id}}" {{ifEquals ../branchId id 'selected'}}>{{name}}</option>
              {{/each}}
            </select>
          </label>
          <div class="modal-actions span-2">
            <button class="btn-secondary" type="button" data-modal-close="manager-edit-{{id}}">Yopish</button>
            <button class="btn-primary" type="submit" data-loading-text="Yangilanmoqda...">Saqlash</button>
          </div>
        </form>
      </div>
    </div>

    <div class="modal" id="manager-password-{{id}}">
      <div class="modal-content modal-sm">
        <button class="modal-close" type="button" data-modal-close="manager-password-{{id}}">×</button>
        <div class="modal-header">
          <h4>{{fullName}} uchun parolni yangilash</h4>
          <p>Yangi parol kamida 6 ta belgidan iborat bo'lsin.</p>
        </div>
        <form action="/app/managers/{{id}}/reset-password" method="POST" class="form-grid">
          <label class="span-2">Yangi parol<input type="password" name="newPassword" required></label>
          <div class="modal-actions span-2">
            <button class="btn-secondary" type="button" data-modal-close="manager-password-{{id}}">Bekor qilish</button>
            <button class="btn-primary" type="submit" data-loading-text="Yangilanmoqda...">Parolni almashtirish</button>
          </div>
        </form>
      </div>
    </div>
  {{/each}}
{{/main}}
