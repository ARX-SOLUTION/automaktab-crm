{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount pageDescription=pageDescription}}
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="page-eyebrow">Boshqaruv paneli</span>
        <h1 class="page-title">{{pageTitle}}</h1>
        <p class="page-description">{{pageDescription}}</p>
      </div>
      <div class="page-actions">
        <a class="btn-secondary" href="/app/students">Talabalar ro'yxati</a>
        {{#if user.isOwner}}
          <a class="btn-primary" href="/app/reports">Hisobotlarni ochish</a>
        {{/if}}
      </div>
    </section>

    <form class="filters-bar filter-card" method="GET" action="/app/dashboard">
      <div class="filter-group">
        <label>Filial</label>
        <select name="branchId" {{#unless user.isOwner}}disabled{{/unless}}>
          {{{branchOptions branches user filters.branchId}}}
        </select>
      </div>
      <div class="filter-group">
        <label>To'lov holati</label>
        <select name="status">
          <option value="">Barchasi</option>
          <option value="paid" {{ifEquals filters.status 'paid' 'selected'}}>To'langan</option>
          <option value="unpaid" {{ifEquals filters.status 'unpaid' 'selected'}}>Qarzdor</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Kurs turi</label>
        <select name="courseType">
          <option value="">Barcha kurslar</option>
          <option value="express" {{ifEquals filters.courseType 'express' 'selected'}}>Tezkor kurs</option>
          <option value="standard" {{ifEquals filters.courseType 'standard' 'selected'}}>To'liq kurs</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Qidiruv</label>
        <input type="search" name="search" value="{{filters.search}}" placeholder="Ism yoki telefon">
      </div>
      <div class="filter-actions">
        <button class="btn-secondary" type="submit">Yangilash</button>
        <a class="btn-ghost" href="/app/dashboard">Tozalash</a>
      </div>
    </form>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M4 19h16M6 16V8m6 8V5m6 11v-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Jami talabalar</span>
          <h3>{{stats.totalStudents}}</h3>
          <small>{{#if user.isOwner}}Barcha filiallar{{else}}{{user.branchName}}{{/if}}</small>
        </div>
      </div>
      <div class="stat-card success">
        <div class="stat-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M6 12l4 4 8-8M4 12c0-4.418 3.582-8 8-8s8 3.582 8 8-3.582 8-8 8-8-3.582-8-8z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Faol talabalar</span>
          <h3>{{stats.activeStudents}}</h3>
          <small>Joriy oqimdagi faol o'quvchilar soni</small>
        </div>
      </div>
      {{#if user.isOwner}}
        <div class="stat-card success">
          <div class="stat-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M4 12h16M12 4v16M6 6h12v12H6z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="stat-body">
            <span class="stat-label">Daromad</span>
            <h3>{{formatUZS stats.totalPaid}}</h3>
            <small>{{stats.paidCount}} ta to'lovi yopilgan talaba</small>
          </div>
        </div>
      {{else}}
        <div class="stat-card info">
          <div class="stat-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14M8 8h8M8 16h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="stat-body">
            <span class="stat-label">Yopilgan to'lovlar</span>
            <h3>{{stats.paidCount}}</h3>
            <small>Qoldiqsiz yakunlangan talabalar</small>
          </div>
        </div>
      {{/if}}
      <div class="stat-card warning">
        <div class="stat-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M12 4v9m0 4h.01M4.93 19h14.14L12 4 4.93 19z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Qarzdorlik</span>
          <h3>{{formatUZS stats.totalDebt}}</h3>
          <small>{{stats.debtCount}} ta talaba bo'yicha ochiq balans</small>
        </div>
      </div>
    </div>

    <div class="dashboard-layout">
      <section class="panel panel-highlight">
        <div class="section-heading">
          <div>
            <h3>Tezkor boshqaruv</h3>
            <p>Kunlik operatsiyalar uchun eng kerakli yo'nalishlar va muhim ko'rsatkichlar.</p>
          </div>
        </div>
        <div class="quick-links">
          <a class="quick-link-card" href="/app/students">
            <strong>Talabalar</strong>
            <span>Ro'yxatni ochish va to'lovlarni boshqarish</span>
          </a>
          {{#if user.isOwner}}
            <a class="quick-link-card" href="/app/managers">
              <strong>Operatorlar</strong>
              <span>Filial operatorlari va hisoblarni nazorat qilish</span>
            </a>
            <a class="quick-link-card" href="/app/reports">
              <strong>Hisobotlar</strong>
              <span>Tushum va qarzdorlik bo'yicha chuqur ko'rinish</span>
            </a>
          {{/if}}
        </div>
        <div class="metric-list">
          <div><span>To'langan talabalar</span><strong>{{stats.paidCount}}</strong></div>
          <div><span>Qarzdor talabalar</span><strong>{{stats.debtCount}}</strong></div>
          {{#if user.isOwner}}
            <div><span>Net ko'rsatkich</span><strong>{{formatUZS stats.totalPaid}}</strong></div>
          {{else}}
            <div><span>Faol filial</span><strong>{{user.branchName}}</strong></div>
          {{/if}}
        </div>
      </section>

      <section class="panel">
        <div class="section-heading">
          <div>
            <h3>Filial signallari</h3>
            <p>Faol filiallar bo'yicha tezkor navigatsiya va nazorat.</p>
          </div>
        </div>
        {{#if branchBreakdown.length}}
          <div class="dashboard-branch-grid">
            {{#each branchBreakdown}}
              <article class="dashboard-branch-card">
                <div class="branch-card-header">
                  <div class="branch-card-meta">
                    <h4>{{branchName}}</h4>
                    <p>{{studentCount}} ta talaba bo'yicha umumiy ko'rinish</p>
                  </div>
                  <span class="branch-badge">{{branchName}}</span>
                </div>
                <div class="branch-card-stats">
                  <div class="branch-card-stat">
                    <span>Daromad</span>
                    <strong>{{formatUZS revenue}}</strong>
                  </div>
                  <div class="branch-card-stat">
                    <span>Qarzdorlik</span>
                    <strong class="{{debtClass debt}}">{{formatUZS debt}}</strong>
                  </div>
                </div>
                <div class="dashboard-mini-stat">
                  <span>Talabalar soni</span>
                  <strong>{{studentCount}}</strong>
                </div>
              </article>
            {{/each}}
          </div>
        {{else}}
          <div class="dashboard-branch-grid">
            <article class="dashboard-branch-card">
              <div class="branch-card-header">
                <div class="branch-card-meta">
                  <h4>{{user.branchName}}</h4>
                  <p>Filialning joriy ishchi ko'rinishi.</p>
                </div>
                <span class="branch-badge">{{user.branchName}}</span>
              </div>
              <div class="branch-card-stats">
                <div class="branch-card-stat">
                  <span>Faol talabalar</span>
                  <strong>{{stats.activeStudents}}</strong>
                </div>
                <div class="branch-card-stat">
                  <span>Qarzdorlik</span>
                  <strong class="{{debtClass stats.totalDebt}}">{{formatUZS stats.totalDebt}}</strong>
                </div>
              </div>
              <div class="dashboard-mini-stat">
                <span>Yopilgan to'lovlar</span>
                <strong>{{stats.paidCount}}</strong>
              </div>
            </article>
          </div>
        {{/if}}
      </section>
    </div>
  </div>
{{/main}}
