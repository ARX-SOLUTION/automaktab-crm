{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount}}
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="page-eyebrow">Boshqaruv paneli</span>
        <h1 class="page-title">{{pageTitle}}</h1>
        <p class="page-description">{{pageDescription}}</p>
      </div>
      <div class="page-actions">
        <a class="btn-secondary" href="/app/students">Talabalar ro'yxati</a>
        {{#if user.isOwner}}
          <a class="btn-primary" href="/app/reports">Hisobotlarni ochish</a>
        {{/if}}
      </div>
    </section>

    <form class="filters-bar filter-card" method="GET" action="/app/dashboard">
      <div class="filter-group">
        <label>Filial</label>
        <select name="branchId" {{#unless user.isOwner}}disabled{{/unless}}>
          {{{branchOptions branches user filters.branchId}}}
        </select>
      </div>
      <div class="filter-group">
        <label>To'lov holati</label>
        <select name="status">
          <option value="">Barchasi</option>
          <option value="paid" {{ifEquals filters.status 'paid' 'selected'}}>To'langan</option>
          <option value="unpaid" {{ifEquals filters.status 'unpaid' 'selected'}}>Qarzdor</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Kurs turi</label>
        <select name="courseType">
          <option value="">Barcha kurslar</option>
          <option value="express" {{ifEquals filters.courseType 'express' 'selected'}}>Tezkor kurs</option>
          <option value="standard" {{ifEquals filters.courseType 'standard' 'selected'}}>To'liq kurs</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Qidiruv</label>
        <input type="search" name="search" value="{{filters.search}}" placeholder="Ism yoki telefon">
      </div>
      <div class="filter-actions">
        <button class="btn-secondary" type="submit">Yangilash</button>
        <a class="btn-ghost" href="/app/dashboard">Tozalash</a>
      </div>
    </form>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon-wrap bg-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Jami talabalar</span>
          <h3>{{stats.totalStudents}}</h3>
          <small>{{#if user.isOwner}}Barcha filiallar{{else}}{{user.branchName}}{{/if}}</small>
        </div>
      </div>
      <div class="stat-card success">
        <div class="stat-icon-wrap bg-success">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">To'langan</span>
          <h3>{{formatUZS stats.totalPaid}}</h3>
          <small>{{stats.paidCount}} ta to'lovsiz qarz yo'q</small>
        </div>
      </div>
      <div class="stat-card warning">
        <div class="stat-icon-wrap bg-danger">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="stat-body">
          <span class="stat-label">Qarzdorlik</span>
          <h3>{{formatUZS stats.totalDebt}}</h3>
          <small>{{#if user.isOwner}}Tizim bo'yicha umumiy qarz{{else}}Filial kesimida{{/if}}</small>
        </div>
      </div>
      {{#if user.isOwner}}
        <div class="stat-card info">
          <div class="stat-icon-wrap bg-info">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <div class="stat-body">
            <span class="stat-label">Filiallar</span>
            <h3>{{stats.branchCount}}</h3>
            <small>{{branchNames}}</small>
          </div>
        </div>
      {{/if}}
    </div>

    <div class="dashboard-panels dashboard-panels-two">
      <section class="panel">
        <div class="section-heading">
          <div>
            <h3>To'lov holati</h3>
            <p>Bugungi kunda to'lovi yopilgan va qarzdor talabalar ulushi.</p>
          </div>
        </div>
        <div class="metric-list">
          <div><span>To'langan</span><strong class="text-success">{{stats.paidCount}}</strong></div>
          <div><span>Qarzdor</span><strong class="text-danger">{{stats.debtCount}}</strong></div>
        </div>
      </section>
      <section class="panel">
        <div class="section-heading">
          <div>
            <h3>Filiallar ro'yxati</h3>
            <p>Faol filiallar va ular bo'yicha tezkor nazorat.</p>
          </div>
        </div>
        <ul class="plain-list">
          {{#each branches}}
            <li style="display:flex;justify-content:space-between;align-items:center">
              <strong>{{name}}</strong>
              <a href="/app/students?branchId={{id}}" class="btn-ghost btn-sm">Ko'rish</a>
            </li>
          {{/each}}
        </ul>
      </section>
    </div>
  </div>
{{/main}}
