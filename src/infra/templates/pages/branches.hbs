{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount}}
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="page-eyebrow">Filiallar</span>
        <h1 class="page-title">{{pageTitle}}</h1>
        <p class="page-description">{{pageDescription}}</p>
      </div>
    </section>

    <section class="resource-section">
      <div class="section-heading">
        <div>
          <h3>Yangi filial</h3>
          <p>Yangi manzil va telefon bilan filialni tizimga qo'shing.</p>
        </div>
      </div>
      <form action="/app/branches" method="POST" class="form-grid inline-form">
        <label>Nomi<input type="text" name="name" required></label>
        <label>Manzil<input type="text" name="address" required></label>
        <label>Telefon<input type="text" name="phone"></label>
        <button class="btn-primary" type="submit">Filial qo'shish</button>
      </form>
    </section>

    <div class="resource-list resource-list-wide">
      {{#each branches}}
        <article class="resource-card">
          <div class="resource-card-header">
            <div>
              <h4>{{name}}</h4>
              <p>{{address}}</p>
            </div>
            <span class="{{#if isActive}}status-pill success{{else}}status-pill danger{{/if}}">
              {{#if isActive}}Faol{{else}}Yopilgan{{/if}}
            </span>
          </div>
          <div class="resource-meta">
            <span>{{#if phone}}{{phone}}{{else}}Telefon kiritilmagan{{/if}}</span>
          </div>
          <form action="/app/branches/{{id}}/update" method="POST" class="form-grid inline-form">
            <label>Nomi<input type="text" name="name" value="{{name}}"></label>
            <label>Manzil<input type="text" name="address" value="{{address}}"></label>
            <label>Telefon<input type="text" name="phone" value="{{phone}}"></label>
            <button class="btn-secondary" type="submit">Yangilash</button>
          </form>
          <form action="/app/branches/{{id}}/delete" method="POST">
            <button class="btn-danger" type="submit">O'chirish</button>
          </form>
        </article>
      {{/each}}
    </div>
  </div>
{{/main}}
