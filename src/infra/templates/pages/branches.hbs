{{#> main title=title pageTitle=pageTitle currentPage=currentPage pageScript=pageScript user=user flash=flash isOwner=isOwner isManager=isManager branchCount=branchCount pageDescription=pageDescription}}
  <div class="page-stack">
    <section class="page-hero">
      <div class="page-hero-copy">
        <span class="page-eyebrow">Filiallar</span>
        <h1 class="page-title">{{pageTitle}}</h1>
        <p class="page-description">{{pageDescription}}</p>
      </div>
      <div class="page-actions">
        <button class="btn-primary" type="button" data-modal-open="branch-create-modal">Yangi filial</button>
      </div>
    </section>

    <form class="filters-bar filter-card" method="GET" action="/app/branches">
      <div class="filter-group">
        <label>Qidiruv</label>
        <input type="search" name="search" value="{{filters.search}}" placeholder="Filial nomi yoki manzil">
      </div>
      <div class="filter-group">
        <label>Status</label>
        <select name="status">
          <option value="">Barchasi</option>
          <option value="active" {{ifEquals filters.status 'active' 'selected'}}>Faol</option>
          <option value="inactive" {{ifEquals filters.status 'inactive' 'selected'}}>Nofaol</option>
        </select>
      </div>
      <div class="filter-actions">
        <button class="btn-secondary" type="submit">Filtrni qo'llash</button>
        <a class="btn-ghost" href="/app/branches">Tozalash</a>
      </div>
    </form>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-body">
          <span class="stat-label">Jami filiallar</span>
          <h3>{{summary.total}}</h3>
          <small>Joriy filter bo'yicha ko'rinayotgan filiallar</small>
        </div>
      </div>
      <div class="stat-card success">
        <div class="stat-body">
          <span class="stat-label">Faol filiallar</span>
          <h3>{{summary.active}}</h3>
          <small>Ishlayotgan filiallar soni</small>
        </div>
      </div>
      <div class="stat-card warning">
        <div class="stat-body">
          <span class="stat-label">Nofaol filiallar</span>
          <h3>{{summary.inactive}}</h3>
          <small>Yopilgan yoki vaqtincha o'chirilgan filiallar</small>
        </div>
      </div>
    </div>

    {{#if branches.length}}
      <section class="panel">
        <div class="section-heading">
          <div>
            <h3>Filial kartalari</h3>
            <p>Tezkor skan qilish uchun asosiy filial signalari shu yerda jamlandi.</p>
          </div>
        </div>
        <div class="branch-card-grid">
          {{#each branches}}
            <article class="branch-card">
              <div class="branch-card-header">
                <div class="branch-card-meta">
                  <h4>{{name}}</h4>
                  <p title="{{address}}">{{address}}</p>
                </div>
                <span class="{{#if isActive}}status-pill success{{else}}status-pill neutral{{/if}}">
                  {{#if isActive}}Faol{{else}}Nofaol{{/if}}
                </span>
              </div>
              <div class="branch-card-stats">
                <div class="branch-card-stat">
                  <span>Telefon</span>
                  <strong>{{#if phone}}{{phone}}{{else}}—{{/if}}</strong>
                </div>
                <div class="branch-card-stat">
                  <span>Operatorlar</span>
                  <strong>{{managerCount}}</strong>
                </div>
              </div>
              <div class="branch-card-footer">
                <span class="cell-muted">{{formatDateUZ createdAt}} dan beri tizimda</span>
                <a class="branch-card-link" href="/app/students?branchId={{id}}">Talabalarni ko'rish</a>
              </div>
            </article>
          {{/each}}
        </div>
      </section>
    {{/if}}

    <section class="data-card">
      <div class="table-card-header">
        <div>
          <h3>Filiallar jadvali</h3>
          <p>Manzil, aloqa va holat bo'yicha barcha filiallarni bir joydan boshqaring.</p>
        </div>
        <span class="badge">{{summary.total}} ta filial</span>
      </div>

      <div class="table-wrapper">
        <table class="data-table compact-table">
          <colgroup>
            <col class="col-name">
            <col class="col-notes">
            <col class="col-phone">
            <col class="col-status">
            <col class="col-status">
            <col class="col-date">
            <col class="col-actions">
          </colgroup>
          <thead>
            <tr>
              <th>Filial</th>
              <th>Manzil</th>
              <th>Telefon</th>
              <th>Operatorlar</th>
              <th>Holat</th>
              <th>Qo'shilgan sana</th>
              <th>Amallar</th>
            </tr>
          </thead>
          <tbody>
            {{#if branches.length}}
              {{#each branches}}
                <tr>
                  <td>
                    <div class="cell-stack">
                      <strong>{{name}}</strong>
                      <span class="cell-muted">{{id}}</span>
                    </div>
                  </td>
                  <td title="{{address}}"><span class="cell-truncate">{{address}}</span></td>
                  <td>{{#if phone}}{{phone}}{{else}}—{{/if}}</td>
                  <td class="tabular-nums">{{managerCount}} ta</td>
                  <td>
                    <span class="{{#if isActive}}status-pill success{{else}}status-pill neutral{{/if}}">
                      {{#if isActive}}Faol{{else}}Nofaol{{/if}}
                    </span>
                  </td>
                  <td>{{formatDateUZ createdAt}}</td>
                  <td class="actions-cell">
                    <button class="btn-icon btn-edit" type="button" data-modal-open="branch-edit-{{id}}">Tahrir</button>
                    <button
                      class="btn-icon btn-delete"
                      type="button"
                      data-modal-open="delete-modal"
                      data-confirm-action="/app/branches/{{id}}/delete"
                      data-confirm-title="Filialni o'chirish"
                      data-confirm-description="{{name}} filialini o'chirsangiz, bu amal qaytarilmaydi."
                      data-confirm-button="Ha, o'chirish"
                    >
                      O'chir
                    </button>
                  </td>
                </tr>
              {{/each}}
            {{else}}
              <tr class="table-empty-row">
                <td colspan="7">{{> empty-state message="Tanlangan filter bo'yicha filial topilmadi" icon="BR" }}</td>
              </tr>
            {{/if}}
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <div class="modal" id="branch-create-modal">
    <div class="modal-content">
      <button class="modal-close" type="button" data-modal-close="branch-create-modal">×</button>
      <div class="modal-header">
        <h3>Yangi filial qo'shish</h3>
        <p>Yangi manzil va aloqa ma'lumotlari bilan filialni tizimga kiriting.</p>
      </div>
      <form action="/app/branches" method="POST" class="form-grid">
        <label>Nomi<input type="text" name="name" placeholder="Masalan, Yunusobod" required></label>
        <label>Telefon<input type="text" name="phone" placeholder="+998 90 123 45 67"></label>
        <label class="span-2">Manzil<input type="text" name="address" placeholder="To'liq manzilni kiriting" required></label>
        <div class="modal-actions span-2">
          <button class="btn-secondary" type="button" data-modal-close="branch-create-modal">Bekor qilish</button>
          <button class="btn-primary" type="submit" data-loading-text="Saqlanmoqda...">Filialni saqlash</button>
        </div>
      </form>
    </div>
  </div>

  {{#each branches}}
    <div class="modal" id="branch-edit-{{id}}">
      <div class="modal-content">
        <button class="modal-close" type="button" data-modal-close="branch-edit-{{id}}">×</button>
        <div class="modal-header">
          <h3>{{name}} filialini tahrirlash</h3>
          <p>Filial nomi, telefon va manzil ma'lumotlarini yangilang.</p>
        </div>
        <form action="/app/branches/{{id}}/update" method="POST" class="form-grid">
          <label>Nomi<input type="text" name="name" value="{{name}}" required></label>
          <label>Telefon<input type="text" name="phone" value="{{phone}}"></label>
          <label class="span-2">Manzil<input type="text" name="address" value="{{address}}" required></label>
          <div class="modal-actions span-2">
            <button class="btn-secondary" type="button" data-modal-close="branch-edit-{{id}}">Yopish</button>
            <button class="btn-primary" type="submit" data-loading-text="Yangilanmoqda...">O'zgarishlarni saqlash</button>
          </div>
        </form>
      </div>
    </div>
  {{/each}}
{{/main}}
