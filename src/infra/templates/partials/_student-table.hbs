<div class="table-shell">
  <div class="table-wrapper">
    <table class="students-table data-table">
      <colgroup>
        <col class="col-index">
        <col class="col-name">
        <col class="col-phone">
        <col class="col-branch">
        <col class="col-course">
        <col class="col-money">
        <col class="col-money">
        <col class="col-money">
        <col class="col-money">
        <col class="col-money">
        <col class="col-method">
        <col class="col-bool">
        <col class="col-bool">
        <col class="col-status">
        <col class="col-status">
        <col class="col-meta">
        <col class="col-operator">
        <col class="col-notes">
        <col class="col-actions">
      </colgroup>
    <thead>
      <tr>
        <th>#</th>
        <th>F.I.SH</th>
        <th>Telefon</th>
        <th>Filial</th>
        <th>Kurs turi</th>
        <th>Kurs narxi</th>
        <th>1-to'lov</th>
        <th>2-to'lov</th>
        <th>3-to'lov</th>
        <th>Qoldiq</th>
        <th>To'lov turi</th>
        <th>Hujjat</th>
        <th>O83</th>
        <th>Holat</th>
        <th>Natija</th>
        <th>Guruh / shartnoma</th>
        <th>Operator</th>
        <th>Izoh</th>
        <th>Amallar</th>
      </tr>
    </thead>
    <tbody>
      {{#if students.length}}
        {{#each students}}
          <tr data-id="{{id}}" data-course-type="{{courseType}}">
            <td>{{add @index 1}}</td>
            <td class="cell-primary" title="{{lastName}} {{firstName}}">
              <div class="cell-stack">
                <strong>{{lastName}} {{firstName}}</strong>
                <span class="cell-muted">{{id}}</span>
              </div>
            </td>
            <td title="{{phone}}">{{phone}}</td>
            <td title="{{branch.name}}">{{branch.name}}</td>
            <td><span class="badge badge-course {{courseType}}">{{courseTypeLabel courseType}}</span></td>
            <td class="text-right tabular-nums">{{formatUZS totalPrice}}</td>
            <td class="text-right tabular-nums">{{formatUZS initialPayment}}</td>
            <td class="text-right tabular-nums">{{formatUZS secondPayment}}</td>
            <td class="text-right tabular-nums">{{formatUZS thirdPayment}}</td>
            <td class="text-right tabular-nums {{debtClass debt}}">
              <strong>{{#if debt}}{{formatUZS debt}}{{else}}To'langan{{/if}}</strong>
            </td>
            <td>{{paymentMethodLabel paymentMethod}}</td>
            <td class="text-center">{{{boolIcon hasDocument}}}</td>
            <td class="text-center">
              {{#ifEquals courseType 'standard'}}
                {{{boolIcon o83}}}
              {{else}}
                <span class="cell-muted">—</span>
              {{/ifEquals}}
            </td>
            <td><span class="{{studentStatusClass status}}">{{studentStatusLabel status}}</span></td>
            <td><span class="{{studentResultClass result}}">{{studentResultLabel result}}</span></td>
            <td title="{{#if group}}{{group.name}}{{/if}}{{#if contractNumber}} {{contractNumber}}{{/if}}">
              <div class="cell-stack">
                <strong>{{#if group}}{{group.name}}{{else}}—{{/if}}</strong>
                <span class="cell-muted">{{#if contractNumber}}{{contractNumber}}{{else}}Shartnoma yo'q{{/if}}</span>
              </div>
            </td>
            <td title="{{registrar.fullName}}">{{registrar.fullName}}</td>
            <td title="{{#if notes}}{{notes}}{{else}}Izoh yo'q{{/if}}">
              {{#if notes}}
                <span class="cell-truncate">{{notes}}</span>
              {{else}}
                <span class="cell-muted">—</span>
              {{/if}}
            </td>
            <td class="actions-cell">
              <button class="btn-icon btn-edit" type="button" data-modal-open="student-edit-{{id}}" title="Tahrirlash">Tahrir</button>
              {{#if ../isOwner}}
                <button class="btn-icon btn-delete" type="button" data-delete-id="{{id}}" title="O'chirish" data-modal-open="delete-modal">O'chir</button>
              {{/if}}
            </td>
          </tr>
        {{/each}}
      {{else}}
        <tr>
          <td colspan="19">{{> empty-state message="Hech qanday talaba topilmadi" icon="—" }}</td>
        </tr>
      {{/if}}
    </tbody>
    {{#if students.length}}
      <tfoot>
        <tr class="summary-row jami-natija">
          <td colspan="5"><strong>Jami natija</strong></td>
          <td class="text-right">{{formatUZS summary.totalPrices}}</td>
          <td class="text-right">{{formatUZS summary.totalInitial}}</td>
          <td class="text-right">{{formatUZS summary.totalSecond}}</td>
          <td class="text-right">{{formatUZS summary.totalThird}}</td>
          <td class="text-right">{{formatUZS summary.totalDebt}}</td>
          <td colspan="9"></td>
        </tr>
        <tr class="summary-row paid">
          <td colspan="5"><strong>Jami to'langan</strong></td>
          <td colspan="5" class="text-right text-success"><strong>{{formatUZS summary.totalPaid}}</strong></td>
          <td colspan="9"></td>
        </tr>
        <tr class="summary-row debt">
          <td colspan="5"><strong>Jami qoldiq</strong></td>
          <td colspan="5" class="text-right text-danger"><strong>{{formatUZS summary.totalDebt}}</strong></td>
          <td colspan="9"></td>
        </tr>
      </tfoot>
    {{/if}}
    </table>
  </div>
</div>
