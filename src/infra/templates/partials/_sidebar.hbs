<aside class="sidebar">
  <div class="sidebar-header">
    <div class="sidebar-brand">
      <p class="sidebar-eyebrow">Boshqaruv paneli</p>
      <h3>Auto Maktab CRM</h3>
      <small>Kunlik operatsiyalar va nazorat bir joyda.</small>
    </div>
    <span class="user-role-badge {{user.role}}">
      {{#if user.isOwner}}Owner{{else}}Manager{{/if}}
    </span>
  </div>
  <div class="sidebar-summary">
    <span class="sidebar-summary-label">{{#if user.isOwner}}Faol filiallar{{else}}Sizning filialingiz{{/if}}</span>
    <strong>{{#if user.isOwner}}{{branchCount}} ta{{else}}{{user.branchName}}{{/if}}</strong>
    <small>{{#if user.isOwner}}Tizim bo'yicha barcha bo'limlar nazoratda{{else}}Kunlik ishlar shu filial bo'yicha yuritiladi{{/if}}</small>
  </div>
  <nav class="sidebar-menu">
    <a href="/app/dashboard" class="menu-item {{activeClass currentPage 'dashboard'}}">
      <span class="menu-item-main">
        <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M4 19h16M7 16V9m5 7V5m5 11v-4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="menu-item-index">01</span>
        <span>Dashboard</span>
      </span>
      <span class="menu-item-hint">Start</span>
    </a>
    <a href="/app/students" class="menu-item {{activeClass currentPage 'students'}}">
      <span class="menu-item-main">
        <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 3.13a4 4 0 0 1 0 7.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="menu-item-index">02</span>
        <span>Talabalar</span>
      </span>
      <span class="menu-item-hint">CRM</span>
    </a>
    {{#if user.isOwner}}
      <a href="/app/branches" class="menu-item {{activeClass currentPage 'branches'}}">
        <span class="menu-item-main">
          <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M9 13h.01M9 17h.01M15 9h.01M15 13h.01M15 17h.01" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="menu-item-index">03</span>
          <span>Filiallar</span>
        </span>
        <span class="badge">{{branchCount}}</span>
      </a>
      <a href="/app/managers" class="menu-item {{activeClass currentPage 'managers'}}">
        <span class="menu-item-main">
          <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 3.13a4 4 0 0 1 0 7.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="menu-item-index">04</span>
          <span>Operatorlar</span>
        </span>
        <span class="menu-item-hint">Team</span>
      </a>
      <a href="/app/reports" class="menu-item {{activeClass currentPage 'reports'}}">
        <span class="menu-item-main">
          <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M4 19h16M7 16V8m5 8V5m5 11v-3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="menu-item-index">05</span>
          <span>Hisobotlar</span>
        </span>
        <span class="menu-item-hint">UZS</span>
      </a>
      <a href="/app/groups/overview" class="menu-item {{activeClass currentPage 'groups'}}">
        <span class="menu-item-main">
          <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M4 6h16M4 12h16M4 18h10" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="menu-item-index">06</span>
          <span>Guruhlar</span>
        </span>
        <span class="menu-item-hint">STD</span>
      </a>
    {{else}}
      <div class="sidebar-branch-info">
        <small>Filial</small>
        <strong>{{user.branchName}}</strong>
      </div>
    {{/if}}
  </nav>
  <div class="sidebar-footer">
    <form action="/app/logout" method="POST">
      <button type="submit" class="btn-sidebar-logout">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Chiqish
      </button>
    </form>
  </div>
</aside>
