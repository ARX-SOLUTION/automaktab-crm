<aside class="sidebar">
  <div class="sidebar-header">
    <div>
      <p class="sidebar-eyebrow">Boshqaruv paneli</p>
      <h3>Auto Test CRM</h3>
    </div>
    <span class="user-role-badge {{user.role}}">
      {{#if user.isOwner}}Owner{{else}}Manager{{/if}}
    </span>
  </div>
  <nav class="sidebar-menu">
    <a href="/app/dashboard" class="menu-item {{activeClass currentPage 'dashboard'}}">
      <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      <span class="menu-text">Dashboard</span>
    </a>
    <a href="/app/students" class="menu-item {{activeClass currentPage 'students'}}">
      <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <span class="menu-text">Talabalar</span>
    </a>
    {{#if user.isOwner}}
      <a href="/app/branches" class="menu-item {{activeClass currentPage 'branches'}}">
        <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span class="menu-text">Filiallar</span>
        <span class="badge">{{branchCount}}</span>
      </a>
      <a href="/app/managers" class="menu-item {{activeClass currentPage 'managers'}}">
        <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <span class="menu-text">Operatorlar</span>
      </a>
      <a href="/app/reports" class="menu-item {{activeClass currentPage 'reports'}}">
        <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        <span class="menu-text">Hisobotlar</span>
      </a>
      <a href="/app/groups/overview" class="menu-item {{activeClass currentPage 'groups'}}">
        <svg class="menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
        <span class="menu-text">Guruhlar</span>
      </a>
    {{else}}
      <div class="sidebar-branch-info">
        <small>Filial</small>
        <strong>{{user.branchName}}</strong>
      </div>
    {{/if}}
  </nav>
  <div class="sidebar-footer">
    <form action="/app/logout" method="POST">
      <button type="submit" class="btn-logout">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1-2 2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Chiqish
      </button>
    </form>
  </div>
</aside>
