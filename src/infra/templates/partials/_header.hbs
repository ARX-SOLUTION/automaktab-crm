<header class="top-bar">
  <div class="top-bar-left">
    <div class="top-bar-brand">
      <span class="top-bar-kicker">Auto Test CRM</span>
      <strong>{{pageTitle}}</strong>
      {{#if pageDescription}}
        <small class="top-bar-description">{{pageDescription}}</small>
      {{/if}}
    </div>
    {{#if user.branchName}}
      <span class="branch-chip">Filial: {{user.branchName}}</span>
    {{/if}}
  </div>
  <div class="top-bar-right">
    <span class="user-role-badge {{user.role}}">
      {{#if user.isOwner}}Owner{{else}}Manager{{/if}}
    </span>
    <div class="user-info">
      <span class="user-avatar">{{initials user.fullName}}</span>
      <span class="user-copy">
        <strong>{{user.fullName}}</strong>
        <small>{{#if user.isOwner}}Tizim egasi{{else}}Filial operatori{{/if}}</small>
      </span>
    </div>
  </div>
</header>
