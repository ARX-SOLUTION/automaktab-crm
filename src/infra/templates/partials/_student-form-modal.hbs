<div class="modal" id="student-create-modal">
  <div class="modal-content modal-lg">
    <button class="modal-close" type="button" data-modal-close="student-create-modal">×</button>
    <h3>Yangi talaba qo'shish</h3>
    <form action="/app/students" method="POST" class="form-grid">
      <label>
        Familiya
        <input type="text" name="lastName" required>
      </label>
      <label>
        Ismi
        <input type="text" name="firstName" required>
      </label>
      <label>
        Telefon
        <input type="tel" name="phone" required>
      </label>
      <label>
        Filial
        <select name="branchId" {{#unless user.isOwner}}disabled{{/unless}}>
          {{#if user.isOwner}}
            {{#each branches}}
              <option value="{{id}}">{{name}}</option>
            {{/each}}
          {{else}}
            <option value="{{user.branchId}}" selected>{{user.branchName}}</option>
          {{/if}}
        </select>
      </label>
      <label>
        Kurs turi
        <select name="courseType" required>
          <option value="express">Tezkor kurs</option>
          <option value="standard">To'liq kurs</option>
        </select>
      </label>
      <label>
        Kurs narxi
        <input type="number" name="totalPrice" min="0" required>
      </label>
      <label>
        To'lov
        <input type="number" name="amountPaid" min="0">
      </label>
      <label>
        Boshlang'ich to'lov
        <input type="number" name="initialPayment" min="0">
      </label>
      <label>
        2-to'lov
        <input type="number" name="secondPayment" min="0">
      </label>
      <label>
        3-to'lov
        <input type="number" name="thirdPayment" min="0">
      </label>
      <label>
        Guruh ID
        <input type="text" name="groupId">
      </label>
      <label>
        Shartnoma raqami
        <input type="text" name="contractNumber">
      </label>
      <label class="span-2">
        Izoh
        <textarea name="notes" rows="3"></textarea>
      </label>
      <div class="modal-actions span-2">
        <button class="btn-secondary" type="button" data-modal-close="student-create-modal">Bekor qilish</button>
        <button class="btn-primary" type="submit">Saqlash</button>
      </div>
    </form>
  </div>
</div>
